# LLM provider — 'sdk' (default, in-process) or 'acp'
ATELIER_LLM_PROVIDER=sdk

# (optional, only if ATELIER_LLM_PROVIDER=acp)
# ATELIER_ACP_ENDPOINT=acp://localhost:5500

# Subscription auth is handled by Claude Code SDK OAuth on first run.
# No API keys here.

# Subscription quota cap for Phase A (0.0~1.0 of daily quota)
ATELIER_QUOTA_CAP=0.20

# Project + inbox roots (relative to cwd)
ATELIER_ARTIFACTS_DIR=./artifacts
ATELIER_INBOX_DIR=./inbox
ATELIER_RUNS_DIR=./runs

# Logging
ATELIER_LOG_LEVEL=INFO
