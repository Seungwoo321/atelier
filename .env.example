# LLM provider — 'sdk' (in-process) or 'acp'
ATELIER_LLM_PROVIDER=sdk

# ACP endpoint (when provider=acp). A command line, e.g.
# ATELIER_ACP_ENDPOINT=npx @zed-industries/claude-code-acp
# Or with the stdio:// prefix:
# ATELIER_ACP_ENDPOINT=stdio://npx @zed-industries/claude-code-acp

# Subscription quota cap (0.0~1.0 of daily quota)
ATELIER_QUOTA_CAP=0.20

# Project + runtime roots (relative to cwd)
ATELIER_ARTIFACTS_DIR=./artifacts
ATELIER_INBOX_DIR=./inbox
ATELIER_RUNS_DIR=./runs

# Logging
ATELIER_LOG_LEVEL=INFO

# Optional integrations (all are opt-in; safe to leave blank)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# TEMPORAL_HOST=localhost:7233
# E2B_API_KEY=
